{
  "name": "tonyai",
  "version": "0.0.0",
  "private": true,
  "description": "TonyAI — Enterprise carbon accounting / ESG SaaS (monorepo)",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @tonyai/db run generate",
    "db:migrate": "pnpm --filter @tonyai/db run migrate",
    "db:seed": "pnpm --filter @tonyai/db run seed",
    "db:reset": "pnpm --filter @tonyai/db run reset"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}

// TonyAI — Prisma schema (Milestone 1 vertical slice)
// Tables live in the Postgres `public` schema; Supabase Auth owns `auth.users`.
// Profile.id mirrors auth.users.id (no cross-schema FK in Prisma).

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  super_admin
  consultant
  data_entry
  executive_viewer
}

enum SubsidiaryStatus {
  active
  inactive
  pending
}

enum ActivityRecordStatus {
  draft
  submitted
  under_review
  approved
  rejected
  locked
}

model Profile {
  id               String                 @id @db.Uuid // = auth.users.id
  email            String                 @unique
  fullName         String                 @map("full_name")
  role             UserRole               @default(data_entry)
  language         String                 @default("en")
  theme            String                 @default("light")
  organisationId   String?                @map("organisation_id") @db.Uuid
  organisation     Organisation?          @relation(fields: [organisationId], references: [id])
  subsidiaryAccess UserSubsidiaryAccess[]
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  @@map("profiles")
}

model Organisation {
  id                String       @id @default(uuid()) @db.Uuid
  legalName         String       @map("legal_name")
  tradingName       String?      @map("trading_name")
  country           String
  geographyCode     String       @map("geography_code")
  sector            String?
  reportingCurrency String       @default("EUR") @map("reporting_currency")
  subsidiaries      Subsidiary[]
  profiles          Profile[]
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  @@map("organisations")
}

model Subsidiary {
  id               String                 @id @default(uuid()) @db.Uuid
  organisationId   String                 @map("organisation_id") @db.Uuid
  organisation     Organisation           @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  legalName        String                 @map("legal_name")
  tradingName      String?                @map("trading_name")
  location         String?
  geographyCode    String                 @map("geography_code")
  businessArea     String?                @map("business_area")
  sector           String?
  designatedPerson String?                @map("designated_person")
  reportingStatus  SubsidiaryStatus       @default(pending) @map("reporting_status")
  includedScopes   Int[]                  @default([1, 2]) @map("included_scopes")
  locations        Location[]
  access           UserSubsidiaryAccess[]
  activityRecords  ActivityRecord[]
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  @@index([organisationId])
  @@map("subsidiaries")
}

model Location {
  id               String     @id @default(uuid()) @db.Uuid
  subsidiaryId     String     @map("subsidiary_id") @db.Uuid
  subsidiary       Subsidiary @relation(fields: [subsidiaryId], references: [id], onDelete: Cascade)
  name             String
  address          String?
  authorizedPerson String?    @map("authorized_person")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  @@index([subsidiaryId])
  @@map("locations")
}

// An activity record is the core data-entry unit: a single activity input for a
// (subsidiary, reporting period, category), plus an IMMUTABLE calculation
// snapshot produced by the calc engine at create/update time (never recomputed
// on read, so historic results survive factor-library changes). It moves through
// a status workflow (draft -> submitted -> under_review -> approved/rejected;
// approved/locked are terminal & immutable). Child of `subsidiaries`, so it is
// tenant-scoped by `subsidiary_id`.
model ActivityRecord {
  id             String               @id @default(uuid()) @db.Uuid
  subsidiaryId   String               @map("subsidiary_id") @db.Uuid
  subsidiary     Subsidiary           @relation(fields: [subsidiaryId], references: [id], onDelete: Cascade)
  reportingYear  Int                  @map("reporting_year")
  reportingPeriod String              @map("reporting_period") // 'monthly' | 'quarterly' | 'annual'
  periodValue    String               @map("period_value") // e.g. "Q1", "January", "Annual"
  category       String // canonical category key, e.g. "Electricity"
  scope          Int // derived from CATEGORY_SCOPE_MAP
  status         ActivityRecordStatus @default(draft)
  activityValue  Float                @map("activity_value")
  activityUnit   String               @map("activity_unit")
  input          Json? // raw structured input as submitted (optional)
  calculation    Json // immutable calc-engine snapshot (tCo2e + factor traceability)
  createdBy      String               @map("created_by") @db.Uuid
  anomalyFlag    Boolean              @default(false) @map("anomaly_flag")
  varianceReason String?              @map("variance_reason")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  @@unique([subsidiaryId, reportingYear, reportingPeriod, periodValue, category])
  @@index([subsidiaryId])
  @@map("activity_records")
}

model UserSubsidiaryAccess {
  userId       String     @map("user_id") @db.Uuid
  subsidiaryId String     @map("subsidiary_id") @db.Uuid
  profile      Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subsidiary   Subsidiary @relation(fields: [subsidiaryId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@id([userId, subsidiaryId])
  @@map("user_subsidiary_access")
}

// Emission factors are REFERENCE DATA, not tenant-scoped: every authenticated
// user may read them (RLS SELECT policy has no tenant predicate). Writes stay on
// the owner/service-role backend (seed). A calculation snapshots the factor it
// used so historic results never change even if a newer version is added later.
model EmissionFactor {
  id             String   @id @default(uuid()) @db.Uuid
  category       String // canonical category key, e.g. "Electricity", "Natural Gas"
  geographyCode  String   @map("geography_code") // UK | TR | EU
  reportingYear  Int      @map("reporting_year")
  scope          Int // 1 (direct) | 2 (purchased energy)
  factorValue    Float    @map("factor_value") // kgCO2e per normalized unit
  factorUnit     String   @map("factor_unit") // e.g. "kgCO2e/kWh"
  normalizedUnit String   @map("normalized_unit") // target unit after normalization, e.g. "kWh"
  methodology    String // e.g. "location-based"
  source         String // provenance, e.g. "DEFRA 2024 GHG Conversion Factors"
  version        String // factor-library version, e.g. "2024.1"
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([category, geographyCode, reportingYear, version])
  @@index([category, geographyCode, reportingYear])
  @@map("emission_factors")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String // create | update | delete
  entity    String // e.g. "subsidiary"
  entityId  String?  @map("entity_id")
  diff      Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@map("audit_log")
}
